{
  "name": "lm-text-editor",
  "version": "0.1.0",
  "private": true,
  "description": "ローカル LLM と協働で技術ブログ記事を執筆・校正するデスクトップエディタ",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "start": "electron .",
    "backend": ".venv\\Scripts\\python.exe -m uvicorn backend.main:app --host 127.0.0.1 --port 8000 --reload"
  },
  "dependencies": {
    "@tiptap/extension-image": "^3.27.2",
    "@tiptap/pm": "^3.27.2",
    "@tiptap/react": "^3.27.2",
    "@tiptap/starter-kit": "^3.27.2",
    "diff-match-patch": "^1.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@types/diff-match-patch": "^1.0.36",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-electron": "^1.1.0"
  }
}
